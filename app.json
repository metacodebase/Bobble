{
  "expo": {
    "name": "Bobble",
    "slug": "Bobble",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/bobble-app-icon.png",
    "scheme": "bobble",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "metadots.bobble.app",
      "buildNumber": "4",
      "usesAppleSignIn": true,
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSMicrophoneUsageDescription": "Bobble uses your microphone to record voice memos and show a live waveform while you speak."
      },
      "appleTeamId": "A9X3L9QMZT"
    },
    "android": {
      "icon": "./src/assets/images/bobble-app-icon.png",
      "versionCode": 4,
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/images/bobble-app-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.metacodebase.Bobble",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./src/assets/images/bobble-main.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0A0F1A",
          "dark": {
            "image": "./src/assets/images/splash-icon.png",
            "backgroundColor": "#0A0F1A"
          }
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Bobble uses your microphone to record voice memos and show a live waveform while you speak."
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.1028741562392-ft0clsr5be90t7ovclfb64uffcu1qrqc"
        }
      ],
      "expo-apple-authentication",
      [
        "expo-build-properties",
        {
          "ios": {
            "extraPods": [
              {
                "name": "AppCheckCore",
                "version": "11.2.0"
              }
            ]
          }
        }
      ],
      "expo-build-properties"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
