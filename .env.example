# Backend origin only — no trailing slash. Paths like /api/health are appended in code.
#
# Local backend:
# EXPO_PUBLIC_API_URL=http://localhost:3000
# Physical device: http://YOUR_MAC_LAN_IP:3000
EXPO_PUBLIC_API_URL=
EXPO_PUBLIC_APP_ENV=development

# Google Sign-In client IDs (from the Firebase / Google Cloud project)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
